# Copy to .env.local and fill in. Never commit real secrets.

# ── Required for production (startup checks enforce in NODE_ENV=production) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLERK_SECRET_KEY=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Token encryption for stored Stripe OAuth tokens (generate a long random string)
COOKIE_ENCRYPTION_KEY=

# ── Clerk (also set NEXT_PUBLIC_* in Vercel dashboard) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Stripe (customer app / pricing) ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_LUCRUM_STRIPE_PUBLISHABLE_KEY=

# Lucrum billing (if using LUCRUM_* Stripe app for subscriptions)
LUCRUM_STRIPE_SECRET_KEY=
LUCRUM_STRIPE_WEBHOOK_SECRET=
LUCRUM_SOLO_MONTHLY_PRICE_ID=
LUCRUM_SOLO_ANNUAL_PRICE_ID=
LUCRUM_GROWTH_MONTHLY_PRICE_ID=
LUCRUM_GROWTH_ANNUAL_PRICE_ID=
LUCRUM_ENTERPRISE_MONTHLY_PRICE_ID=
LUCRUM_ENTERPRISE_ANNUAL_PRICE_ID=

# ── Cron / automation (must match Authorization: Bearer on scheduled jobs) ──
CRON_SECRET=

# ── Optional ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=
HOLD_TOKEN_SECRET=
NEXT_PUBLIC_DEMO_MODE=false

# AI providers (at least one recommended for MAX)
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
NVIDIA_API_KEY=
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_HEAVY_URL=
RUNPOD_ENDPOINT_CHAT_URL=

# ── Escape hatches ──
# SKIP_STARTUP_CHECKS=1
# LUCRUM_READ_SUGGEST_ONLY=1
