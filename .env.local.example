# Local development
OLLAMA_URL=http://localhost:11434

# RunPod (set these when deploying to production)
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_HEAVY_URL=
RUNPOD_ENDPOINT_CHAT_URL=

# Fallback (Together.ai)
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# AI provider
# AI_PROVIDER can be "groq" or "gemini" (defaults to groq if GROQ_API_KEY exists)
AI_PROVIDER=groq

# Groq (primary)
GROQ_API_KEY=sk_groq_your_key_here
GROQ_REASONING_MODEL=moonshotai/kimi-k2
GROQ_REASONING_FALLBACK=qwen-qwq-32b
GROQ_CHAT_MODEL=meta-llama/llama-4-scout
GROQ_CHAT_FALLBACK=llama-3.3-70b-versatile
GROQ_STRUCTURED_MODEL=qwen-qwq-32b

# Gemini (fallback provider for some flows)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/connect
COOKIE_ENCRYPTION_KEY=replace_with_a_long_random_secret

# Lucrum billing
LUCRUM_STRIPE_SECRET_KEY=
LUCRUM_STRIPE_WEBHOOK_SECRET=
LUCRUM_PRO_PRICE_ID=
LUCRUM_PRO_ANNUAL_PRICE_ID=

# ── Decision Engine ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
OPERATOR_EMAIL=founder@yourdomain.com

# Vercel KV
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Comp Benchmark Scraper (Vercel cron)
CRON_SECRET=

# Demo mode (use fake Stripe-connected metrics when real Stripe is unavailable)
NEXT_PUBLIC_DEMO_MODE=false
LUCRUM_DEMO_MODE=false
