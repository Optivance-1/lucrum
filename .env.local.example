# ── Auth ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/connect

# ── Stripe Connect OAuth ──
# Create a Connect application at: dashboard.stripe.com/settings/connect
# Add https://your-domain.com/api/stripe/callback as authorized redirect URI
LUCRUM_STRIPE_CLIENT_ID=ca_xxx     # Client ID from Stripe Connect settings

# ── Stripe API (for Lucrum's billing and Connect token exchange) ──
LUCRUM_STRIPE_SECRET_KEY=sk_test_... # Lucrum's own Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_APP_SIGNING_SECRET=         # from Stripe App Dashboard (for marketplace app)

# ── Encryption ──
COOKIE_ENCRYPTION_KEY=             # Used for encrypting OAuth access tokens

# ── Lucrum Billing (Lucrum's own Stripe) ──
LUCRUM_STRIPE_SECRET_KEY=
LUCRUM_STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_LUCRUM_STRIPE_PUBLISHABLE_KEY=

# ── Lucrum Billing — 6 price IDs needed ──
LUCRUM_SOLO_MONTHLY_PRICE_ID=        # $19/mo
LUCRUM_SOLO_ANNUAL_PRICE_ID=         # $190/yr
LUCRUM_GROWTH_MONTHLY_PRICE_ID=      # $49/mo (new)
LUCRUM_GROWTH_ANNUAL_PRICE_ID=       # $490/yr (new)
LUCRUM_ENTERPRISE_MONTHLY_PRICE_ID=  # $99/mo
LUCRUM_ENTERPRISE_ANNUAL_PRICE_ID=   # $990/yr

# ── Legacy (backward compat — map to Solo) ──
LUCRUM_PRO_PRICE_ID=
LUCRUM_PRO_ANNUAL_PRICE_ID=

# ── Public price IDs for /pricing page ──
NEXT_PUBLIC_LUCRUM_SOLO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_LUCRUM_SOLO_ANNUAL_PRICE_ID=
NEXT_PUBLIC_LUCRUM_GROWTH_MONTHLY_PRICE_ID=
NEXT_PUBLIC_LUCRUM_GROWTH_ANNUAL_PRICE_ID=
NEXT_PUBLIC_LUCRUM_ENTERPRISE_MONTHLY_PRICE_ID=
NEXT_PUBLIC_LUCRUM_ENTERPRISE_ANNUAL_PRICE_ID=

# ── GLM-5 via NVIDIA NIM (free 6 months) ──
NVIDIA_API_KEY=               # from build.nvidia.com
NVIDIA_GLM_MODEL=thudm/glm-4-9b-chat  # confirm exact model at build.nvidia.com

# ── AI Providers ──
GROQ_API_KEY=
GROQ_REASONING_MODEL=moonshotai/kimi-k2
GROQ_REASONING_FALLBACK=qwen-qwq-32b
GROQ_CHAT_MODEL=meta-llama/llama-4-scout
GROQ_CHAT_FALLBACK=llama-3.3-70b-versatile
GOOGLE_AI_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_HEAVY_MODEL=mistral:latest
OLLAMA_FAST_MODEL=llama3.1:8b

# ── RunPod (future) ──
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_HEAVY_URL=
RUNPOD_ENDPOINT_CHAT_URL=

# ── Storage ──
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Email ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
OPERATOR_EMAIL=

# ── App ──
NEXT_PUBLIC_APP_URL=https://lucrum.vercel.app
NEXT_PUBLIC_DEMO_MODE=false
CRON_SECRET=
